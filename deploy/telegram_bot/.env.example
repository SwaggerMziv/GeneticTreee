# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Backend API (внешний URL бэкенда)
BACKEND_URL=https://api.yourdomain.com

# OpenRouter (основной AI)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key

# Whisper (локальная модель для распознавания голосовых)
# Доступные размеры: tiny, base, small, medium, large-v3
# small — хороший баланс качества и скорости (~461 MB, ~2 GB RAM)
WHISPER_MODEL_SIZE=small
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8

# Рассылка
BROADCAST_ENABLED=true

# Mini App (WebApp)
WEBAPP_URL=https://yourdomain.com
WEBAPP_PORT=8080
WEBAPP_JWT_SECRET=change-me-in-production
WEBAPP_STATIC_DIR=webapp_frontend/out
